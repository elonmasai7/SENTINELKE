CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this
ML_SERVICE_URL=http://ml-service:9000
LLAMA_CPP_URL=http://llama-cpp:8080
WEB_DASHBOARD_URL=https://sentinelke.local
USSD_BASE_URL=http://ussd-service:8050
USSD_TARGET_URL=http://web:8000/api/integrations/ussd/africastalking/
