AI_SERVICE_URL=https://sentinelke.local/ai
MAP_SERVICE_URL=https://tile.openstreetmap.org
SKIP_EXTERNAL_HEALTHCHECKS=False
OPEN_BROWSER_ON_START=False
ENABLE_MOBILE_EMULATOR=False
CLAUDE_API_KEY=
